def enc(plaintext: str, format: str, secret: str) -> str: ...
def dec(obtext: str, format: str, secret: str) -> str: ...
def enc_keyless(plaintext: str, format: str) -> str: ...
def dec_keyless(obtext: str, format: str) -> str: ...

# ============================================================================
# Exception hierarchy
# ============================================================================

class ObuError(Exception):
    """Base class for all obu exceptions."""
    ...

class InvalidSecret(ObuError):
    """Bad hex secret / wrong length."""
    ...

class InvalidFormat(ObuError):
    """Unknown scheme / encoding / malformed format string."""
    ...

class EncryptionFailed(ObuError):
    """Empty plaintext / 0x01 pad-byte rejection."""
    ...

class DecryptionFailed(ObuError):
    """obtext-decode, block-length, payload-shape, or UTF-8 failure."""
    ...
