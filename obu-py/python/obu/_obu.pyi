"""
Type stubs for the _obu native Rust extension module.

These stubs enable IDE autocompletion (VS Code, PyCharm), mypy, and
pyright support for the obu Python bindings.

Only the classes shipped in the default wheel are stubbed. The
testing-only ``Zmock1*`` classes (``mock`` feature) and the deprecated
``Legacy`` codec (``legacy`` feature) are not part of the published
surface and are intentionally omitted.
"""

from typing import Optional

__version__: str

